# Umgebungsvariablen für VTB Vereinsverwaltung
# Kopiere diese Datei nach .env und fülle die Werte aus

# ===========================================
# Basis-Konfiguration
# ===========================================

# Datenbank (PostgreSQL) – Lokale Direktverbindung
# Format: postgresql://BENUTZER:PASSWORT@HOST:PORT/DATENBANKNAME
VTB_DATABASE_URL=postgresql://vtb:vtb_dev@localhost:5432/verein

# PostgreSQL-Credentials für docker-compose.v2.yml
# (Der Compose-Stack baut VTB_DATABASE_URL daraus zusammen)
VTB_PG_USER=vtb
VTB_PG_PASSWORD=SICHERES_PASSWORT_HIER
VTB_PG_DB=verein

# Server-Konfiguration
VTB_HOST=0.0.0.0
VTB_PORT=8080

# Security (WICHTIG: Ändere diesen Wert in Produktion!)
VTB_STORAGE_SECRET=CHANGE_ME_IN_PRODUCTION

# Session-Cookie (HttpOnly): trägt das JWT statt localStorage.
# In Produktion (HTTPS) auf true lassen; für lokale http-Entwicklung auf false
# setzen, sonst verwirft der Browser das Cookie.
VTB_COOKIE_SECURE=true

# ===========================================
# E-Mail-Konfiguration für Magic-Link-Versand
# ===========================================

# SMTP-Server-Einstellungen
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# SMTP-Credentials
# Für Gmail: App-Passwort erstellen unter https://myaccount.google.com/apppasswords
SMTP_USERNAME=deine-email@gmail.com
SMTP_PASSWORD=dein-app-passwort

# Absender-Adresse
MAIL_FROM=VTB Verein <vereinsverwaltung@gmail.com>

# Basis-URL der Anwendung (für Links in E-Mails)
BASE_URL=http://localhost:8080

# ===========================================
# Upload-Konfiguration für Anhänge
# ===========================================

# Speicherpfad für hochgeladene Dateien (Fotos, PDFs)
# Lokal: uploads/  |  Docker: /data/uploads/
VTB_UPLOAD_PATH=uploads/

# Maximale Upload-Größe pro Datei in MB (default: 10)
VTB_MAX_UPLOAD_MB=10

# ===========================================
# TTLock / Zutrittskontrolle
# ===========================================
#
# Developer-Account-Portal: https://euopen.ttlock.com  (dort clientId/clientSecret holen)
# API-Host hingegen ist euapi.ttlock.com (EU) – NICHT euopen.* (das ist nur das Portal).
# TTLOCK_USERNAME/PASSWORD = das TTLock-Benutzerkonto, das die Schlösser verwaltet.
# Hinweis: Das Skript hasht das Passwort selbst als MD5 – hier KLARTEXT eintragen.
TTLOCK_ENDPOINT=https://euapi.ttlock.com
TTLOCK_CLIENT_ID=
TTLOCK_CLIENT_SECRET=
TTLOCK_USERNAME=
TTLOCK_PASSWORD=

# ===========================================
# Passwort-Tresor (#85)
# ===========================================
#
# Symmetrischer Schlüssel für die At-rest-Verschlüsselung der im Tresor gespeicherten
# Passwörter (Fernet, urlsafe-base64, 32 Byte). Ohne gültigen Key ist das Tresor-Feature
# deaktiviert – die App läuft normal weiter, aber Anzeigen/Speichern von Passwörtern
# liefert HTTP 503; die reinen Metadaten (Titel/Benutzer/URL) bleiben lesbar.
#
# WICHTIG: Schlüssel sicher und dauerhaft aufbewahren – geht er verloren, sind ALLE
# gespeicherten Passwörter unwiederbringlich. In Produktion nicht diesen Platzhalter
# (leer) und keinen Beispielwert aus der Doku verwenden, sondern einen eigenen Key.
# Neuen Key erzeugen:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VTB_VAULT_KEY=

# ===========================================
# Alternative SMTP-Provider
# ===========================================
# 
# Strato:
# SMTP_SERVER=smtp.strato.de
# SMTP_PORT=465
# SMTP_USE_TLS=false  # Strato nutzt SSL statt TLS
#
# 1&1 / IONOS:
# SMTP_SERVER=smtp.ionos.de
# SMTP_PORT=587
#
# Mailtrap (Testing):
# SMTP_SERVER=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
