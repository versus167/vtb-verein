# Umgebungsvariablen für VTB Vereinsverwaltung
# Kopiere diese Datei nach .env und fülle die Werte aus

# ===========================================
# Basis-Konfiguration
# ===========================================

# Datenbank
# Hinweis: Bei Docker-Nutzung MUSS der Pfad /data/verein.db sein (Volume-Mapping)
VTB_DB_PATH=verein.db

# Server-Konfiguration
VTB_HOST=0.0.0.0
VTB_PORT=8080

# Security (WICHTIG: Ändere diesen Wert in Produktion!)
VTB_STORAGE_SECRET=CHANGE_ME_IN_PRODUCTION

# ===========================================
# E-Mail-Konfiguration für Magic-Link-Versand
# ===========================================

# SMTP-Server-Einstellungen
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# SMTP-Credentials
# Für Gmail: App-Passwort erstellen unter https://myaccount.google.com/apppasswords
SMTP_USERNAME=deine-email@gmail.com
SMTP_PASSWORD=dein-app-passwort

# Absender-Adresse
MAIL_FROM=VTB Verein <vereinsverwaltung@gmail.com>

# Basis-URL der Anwendung (für Links in E-Mails)
BASE_URL=http://localhost:8080

# ===========================================
# Alternative SMTP-Provider
# ===========================================
# 
# Strato:
# SMTP_SERVER=smtp.strato.de
# SMTP_PORT=465
# SMTP_USE_TLS=false  # Strato nutzt SSL statt TLS
#
# 1&1 / IONOS:
# SMTP_SERVER=smtp.ionos.de
# SMTP_PORT=587
#
# Mailtrap (Testing):
# SMTP_SERVER=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
