# Konfiguration für tools/vtb_tickets.py
# Kopieren nach tools/tickets.local.env und ausfüllen (wird NICHT eingecheckt).

# Basis-URL der laufenden App (ohne /api, ohne abschließenden Slash)
VTB_TICKETS_URL=https://verein.example.de

# Service-User mit Lese-/Bearbeiten-Recht im Bereich "VTB-App"
VTB_TICKETS_USER=claude-bot
VTB_TICKETS_PASS=changeme

# Bereichsname (optional, Default: VTB-App)
VTB_TICKETS_BEREICH=VTB-App
